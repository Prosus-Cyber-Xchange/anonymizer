# Required environment variables
PORT=8080
GRACEFUL_SHUTDOWN_TIMEOUT=30s
LOG_LEVEL=info
PATTERN_MONITORING_ENABLED=true

# Privacy Service Configuration
PRIVACY_CACHE_ENABLED=true
PRIVACY_CACHE_TTL=20m

# Disable client-side (in-memory) caching backed by server-assisted CSC
PRIVACY_CACHE_DISABLE_IN_MEMORY=false

# Valkey/Redis backend
PRIVACY_CACHE_REDIS_ADDR=localhost:6379
PRIVACY_CACHE_REDIS_DISABLE_CLUSTER=false
PRIVACY_CACHE_REDIS_POOL_SIZE=10
PRIVACY_CACHE_REDIS_MIN_IDLE_CONNS=3

PRIVACY_CONCURRENCY_ENABLED=true
PRIVACY_CONCURRENCY_RULE_PROCESSING=true
PRIVACY_CONCURRENCY_RULE_RUNNER_POOL_SIZE=50
PRIVACY_CONCURRENCY_TOKEN_PROCESSING=true
PRIVACY_CONCURRENCY_TOKEN_POOL_SIZE=50
PRIVACY_CONCURRENCY_MAX_GOROUTINE_IDLE_TIMEOUT=5s